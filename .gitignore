# Compiled binaries produced by `go build` inside the repo (e.g. when
# running examples from the repo root). The Go toolchain emits these to
# the working directory; they are not source.
#
# Leading slash anchors each pattern to the repo root so we don't
# accidentally also ignore similarly-named package directories.
/multi_tool
/steering
/with_hooks
/hello_agent
/bounded_results
/observability
/snapshot_resume

# Coverage / profiling output.
/coverage.out
*.prof
*.test
